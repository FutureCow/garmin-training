DATABASE_URL=postgresql+asyncpg://garmin:password@localhost/garmin_training
JWT_SECRET=change-this-to-a-long-random-secret
FERNET_KEY=your-fernet-key-here
ANTHROPIC_API_KEY=sk-ant-...
GARMIN_HOME_DIR=/opt/garmin-training/garmin-home
GARMIN_MCP_PATH=/opt/garmin-connect-mcp/dist/index.js
PLAYWRIGHT_BROWSERS_PATH=/opt/playwright

# GARMIN_HOME_DIR: map waar per-gebruiker HOME-directories worden aangemaakt.
# garmin-connect-mcp slaat de sessie op in $HOME/.garmin-connect-mcp/session.json.
# Door per gebruiker een aparte HOME in te stellen zijn sessies geïsoleerd.
#
# GARMIN_MCP_PATH: pad naar de gecompileerde garmin-connect-mcp server.
# Installeren:
#   git clone https://github.com/etweisberg/garmin-connect-mcp /opt/garmin-connect-mcp
#   cd /opt/garmin-connect-mcp && npm install && npm run build
#
# Eerste Garmin-login per gebruiker (eenmalig, na registratie in de app):
#   HOME=/opt/garmin-training/garmin-home/<user_id> \
#     node /opt/garmin-connect-mcp/dist/index.js login
# Dit opent een browser — gebruik Xvfb op servers zonder scherm.
#
# To generate a Fernet key locally:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
