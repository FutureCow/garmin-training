DATABASE_URL=postgresql+asyncpg://garmin:password@localhost/garmin_training
JWT_SECRET=change-this-to-a-long-random-secret
FERNET_KEY=your-fernet-key-here
ANTHROPIC_API_KEY=sk-ant-...
GARMIN_MCP_PATH=/opt/garmin-connect-mcp/dist/index.js

# Note on garmin-connect-mcp:
# This is installed on the Linux server only.
# On the Linux server, install with:
#   git clone https://github.com/etweisberg/garmin-connect-mcp /opt/garmin-connect-mcp
#   cd /opt/garmin-connect-mcp
#   npm install
#   npm run build
#   # Verify: ls /opt/garmin-connect-mcp/dist/index.js
#
# To generate a Fernet key locally:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
