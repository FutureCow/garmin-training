DATABASE_URL=postgresql+asyncpg://garmin:password@localhost/garmin_training
JWT_SECRET=change-this-to-a-long-random-secret
FERNET_KEY=your-fernet-key-here
ANTHROPIC_API_KEY=sk-ant-...
GARMIN_TOKENS_DIR=/opt/garmin-training/garmin-tokens

# GARMIN_TOKENS_DIR: map waar per-gebruiker Garmin sessie-tokens worden opgeslagen.
# pirate-garmin slaat hier OAuth-tokens op zodat na de eerste login geen browser meer nodig is.
# De map moet schrijfbaar zijn voor de garmin-servicegebruiker.
#
# Eerste keer inloggen per gebruiker (eenmalig, als de garmin-user op de server):
#   pirate-garmin login --app-dir=/opt/garmin-training/garmin-tokens/<user_id>
#
# Of gebruik GARMIN_USERNAME / GARMIN_PASSWORD env vars bij het opstarten van de app.
# Playwright (Chromium) is vereist voor de eerste authenticatie:
#   playwright install chromium
#
# To generate a Fernet key locally:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
